{
  "format": "kpa-manifest",
  "version": 2,
  "app_id": "dev.koto.samples.json-weather",
  "name": "SDK JSON Weather",
  "entry": "bytecode/sample_json_weather.kbc",
  "runtime": "kotoruntime-bytecode",
  "icon": "icons/sample_json_weather.kicon",
  "description": "Streams fetched JSON through the bounded decoder.",
  "category": "Samples",
  "memory": {
    "sram_work_bytes": 16384,
    "psram_cache_bytes": 32768
  },
  "assets": [
    {
      "path": "bytecode/sample_json_weather.kbc",
      "type": "bytecode",
      "sequential": true
    },
    {
      "path": "icons/sample_json_weather.kicon",
      "type": "image",
      "sequential": false
    }
  ],
  "permissions": {
    "fs": "sandbox",
    "network": {
      "origins": [
        "https://weather.example"
      ]
    }
  }
}
