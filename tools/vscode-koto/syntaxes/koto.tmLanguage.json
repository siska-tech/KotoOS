{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Koto",
  "scopeName": "source.koto",
  "patterns": [
    { "include": "#comments" },
    { "include": "#include" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#enum-member" },
    { "include": "#enum-def" },
    { "include": "#struct-def" },
    { "include": "#static-def" },
    { "include": "#member" },
    { "include": "#function-def" },
    { "include": "#call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.koto",
      "match": "//.*$"
    },
    "include": {
      "match": "^\\s*(include)\\s+(\"[^\"]*\")\\s*;",
      "captures": {
        "1": { "name": "keyword.control.import.koto" },
        "2": { "name": "string.quoted.double.include.koto" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.koto",
          "match": "\\b(if|else|while|loop|break|continue|return)\\b"
        },
        {
          "name": "storage.type.koto",
          "match": "\\b(fn|let|const|buf|data|enum|struct|static|impl)\\b"
        }
      ]
    },
    "types": {
      "name": "storage.type.primitive.koto",
      "match": "\\b(int|bool)\\b"
    },
    "constants": {
      "name": "constant.language.boolean.koto",
      "match": "\\b(true|false)\\b"
    },
    "strings": {
      "name": "string.quoted.double.koto",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.koto",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.koto",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.decimal.koto",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "function-def": {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.koto" },
        "2": { "name": "entity.name.function.koto" }
      }
    },
    "enum-def": {
      "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.koto" },
        "2": { "name": "entity.name.type.enum.koto" }
      }
    },
    "struct-def": {
      "match": "\\b(struct|impl)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.koto" },
        "2": { "name": "entity.name.type.struct.koto" }
      }
    },
    "static-def": {
      "match": "\\b(static)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.koto" },
        "2": { "name": "variable.other.constant.koto" },
        "3": { "name": "punctuation.separator.type.koto" },
        "4": { "name": "entity.name.type.struct.koto" }
      }
    },
    "member": {
      "match": "(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.accessor.koto" },
        "2": { "name": "variable.other.member.koto" }
      }
    },
    "enum-member": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(::)\\s*([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "entity.name.type.enum.koto" },
        "2": { "name": "punctuation.accessor.koto" },
        "3": { "name": "constant.other.enum.koto" }
      }
    },
    "call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.koto" }
      }
    },
    "operators": {
      "name": "keyword.operator.koto",
      "match": "(<<|>>|&&|\\|\\||[=!<>]=|[-+*/%&|^!<>=])"
    }
  }
}
