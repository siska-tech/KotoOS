// Dirty-rectangle drawing sample: redraw only a narrow band and moving square.

fn main() {
    let x = 0;

    loop {
        let intent = text_intent();
        if (intent & INTENT_EXIT) != 0 {
            exit(0);
        }

        draw_rect(0, 72, 320, 40, 0);
        draw_rect(x, 80, 24, 24, 65535);
        draw_text(16, 24, "dirty rect sample", 17);
        x = x + 8;
        if x > 296 {
            x = 0;
        }
        yield_frame();
    }
}
