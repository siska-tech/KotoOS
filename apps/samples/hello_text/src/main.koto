// Minimal drawing sample: clear the frame and draw static SDK text.

fn main() {
    loop {
        let intent = text_intent();
        if (intent & INTENT_EXIT) != 0 {
            exit(0);
        }

        draw_rect(0, 0, 320, 320, 0);
        draw_text(16, 24, "hello from KotoSDK", 18);
        draw_text(16, 44, "press F10 to exit", 17);
        yield_frame();
    }
}
