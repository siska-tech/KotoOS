// Cooperative frame-loop sample: locals persist across yield_frame().

fn main() {
    buf digit[1];
    let count = 0;

    loop {
        let intent = text_intent();
        if (intent & INTENT_EXIT) != 0 {
            exit(0);
        }

        digit[0] = 48 + (count % 10);
        draw_rect(0, 0, 320, 320, 0);
        draw_text(16, 24, "frame counter:", 14);
        draw_text(136, 24, digit, 1);
        count = count + 1;
        yield_frame();
    }
}
