  "codegen": {
    "comment": "KOTO-0156: the per-frame loop body exceeds one 16 KiB PSRAM code-window tile. Relocating the one-time string-init preamble to the tail (relocate_preamble) AND outlining the cold title-state block (outline_cold_blocks) together front-load the steady loop into a single tile -> steady gameplay refills 2 -> 0. Neither alone wins (preamble-only regresses to 442 refills, outline-only to 14); only the pair. See docs/devlog/KOTO_KOTOBLOCKS_COLD_BLOCK_OUTLINING.md.",
    "relocate_preamble": true,
    "outline_cold_blocks": true
  },
